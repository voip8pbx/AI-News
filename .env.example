# GNews API Configuration
# Add your GNews API keys here - you can get them from https://gnews.io/
VITE_GNEWS_API_KEY=your_primary_gnews_api_key_here
VITE_GNEWS_FALLBACK_API_KEY=your_fallback_gnews_api_key_here
VITE_GNEWS_TERTIARY_API_KEY=your_tertiary_gnews_api_key_here
VITE_GNEWS_QUATERNARY_API_KEY=your_quaternary_gnews_api_key_here
VITE_GNEWS_QUINARY_API_KEY=your_quinary_gnews_api_key_here

# OpenRouter API Configuration (for AI content processing)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_OPENROUTER_FALLBACK_API_KEY=your_openrouter_fallback_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Cron Job Configuration
# Set to true to enable cron jobs in development
VITE_ENABLE_CRON_JOBS=true

# Cron Job Intervals (in cron format)
# Default: Every hour (0 * * * *)
# Options: 
# - Every 30 minutes: */30 * * * *
# - Every 6 hours: 0 */6 * * *
# - Every 12 hours: 0 */12 * * *
# - Daily at midnight: 0 0 * * *
VITE_DEFAULT_CRON_INTERVAL=0 * * * *

# Daily Counter Reset Time (24-hour format)
VITE_DAILY_RESET_TIME=00:00

# Article Processing Limits
VITE_MAX_ARTICLES_PER_RUN=20
VITE_MAX_ARTICLES_PER_DAY=100

# Database Cleanup
# Automatically delete articles older than X days (set to 0 to disable)
VITE_AUTO_CLEANUP_DAYS=30
